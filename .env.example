# =============================================================================
# Eskwelabs AI Advisor - Environment Variables
# Copy to .env and fill in values. Do not commit .env to git.
# =============================================================================

# --- Shared (used by rag-service + web) ---
GEMINI_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=

# --- Google Docs (RAG corpus + advisor prompts) ---
# Doc IDs are the Google Doc file IDs (from the document URL)
DOC_ID_COMPANY_DNA=
DOC_ID_ADVISOR1=
DOC_ID_ADVISOR2=
DOC_ID_ADVISOR3=

# Service account JSON as a single-line string (read-only Docs API access)
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Next.js web app (web/) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# RAG service URL (local dev or deployed Render/Fly URL)
RAG_SERVICE_URL=http://localhost:8001
RAG_SERVICE_SECRET=change-me-in-production

# Optional: override default Gemini model
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Legacy root FastAPI app (optional, pre-overhaul) ---
SECRET_KEY=
