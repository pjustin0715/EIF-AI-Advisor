# =============================================================================
# Eskwelabs AI Advisor - Environment Variables
# Copy to .env and fill in values. Do not commit .env to git.
# =============================================================================

# --- Shared (used by rag-service + web) ---
GEMINI_API_KEY=
# OPENROUTER_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=

# --- Google Docs (RAG corpus + advisor prompts) ---
DOC_ID_COMPANY_DNA=
DOC_ID_ADVISOR1=
DOC_ID_ADVISOR2=
DOC_ID_ADVISOR3=
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Google OAuth (Google Identity Services — no client secret needed) ---
GOOGLE_CLIENT_ID=
SECRET_KEY=

# --- RAG service ---
RAG_SERVICE_URL=http://localhost:8001
RAG_SERVICE_SECRET=change-me-in-production

# --- Optional ---
GEMINI_MODEL=gemini-2.5-flash-lite
