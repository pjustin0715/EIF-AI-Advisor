# =============================================================================
# Eskwelabs AI Advisor - Environment Variables
# Copy to .env and fill in values
# =============================================================================

# --- Shared ---
GEMINI_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=

# --- Google Docs (RAG corpus) ---
GOOGLE_SERVICE_ACCOUNT_JSON=
DOC_ID_COMPANY_DNA=
DOC_ID_ADVISOR1=
DOC_ID_ADVISOR2=
DOC_ID_ADVISOR3=

# --- Next.js (web/) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RAG_SERVICE_URL=http://localhost:8001
RAG_SERVICE_SECRET=change-me-in-production
GEMINI_MODEL=gemini-2.5-flash-lite

# --- FastAPI RAG service (rag-service/) ---
# Uses same GEMINI_API_KEY, SUPABASE_*, DOC_ID_*, GOOGLE_SERVICE_ACCOUNT_JSON
RAG_SERVICE_SECRET=change-me-in-production
